<Window x:Class="MCS_Software.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Client Document Manager"
        Height="900"
        Width="1250"
        MinHeight="650"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="10"
                Padding="18"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="My Travel Agency Manager"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>
                    <TextBlock Text=""
                               FontSize="13"
                               Foreground="#6B7280"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Refresh"
                            Width="90"
                            Height="34"
                            Margin="0,0,10,0"/>
                    <Button Content="Add New Client"
                            Width="130"
                            Height="34"
                            FontWeight="SemiBold"
                            Click="AddNewClient_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left sidebar -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Client Database"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>

                    <TextBox Grid.Row="1"
                             Height="34"
                             Margin="0,12,0,10"
                             VerticalContentAlignment="Center"
                             Text="Search by name, surname, or client ID"/>

                    <ComboBox Grid.Row="2"
                              Height="34"
                              Margin="0,0,0,12"
                              SelectedIndex="0">
                        <ComboBoxItem Content="All Clients"/>
                        <ComboBoxItem Content="Recently Added"/>
                        <ComboBoxItem Content="With Active Documents"/>
                        <ComboBoxItem Content="Archived"/>
                    </ComboBox>

                    <Border Grid.Row="3"
                            Background="#F9FAFB"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8">
                        <ListBox BorderThickness="0"
                                 Background="Transparent"
                                 SelectionChanged="ClientList_SelectionChanged"
                                 x:Name="ClientList">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                            FontSize="14">
                                            <Run Text="{Binding FullName}" />       
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>
                    </Border>
                </Grid>
            </Border>
            
            <!-- right side -->
            <Grid Grid.Column="2">


                <Border x:Name="NoClientSelectedView"
                        Background="White"
                        CornerRadius="10"
                        Padding="18"
                        Visibility="Visible">
                    <Border Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="30"
                        Width="420"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="No client selected"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                            <TextBlock Text="Select a client from the left side or add a new client to begin."
                           FontSize="14"
                           Foreground="#6B7280"
                           TextAlignment="Center"
                           Margin="0,0,0,20"/>
                            <Button Content="Add New Client"
                        Width="150"
                        Height="36"
                        Click="AddNewClient_Click"/>
                        </StackPanel>
                    </Border>
                </Border>

                <Border x:Name="SelectedClientView"
                    Background="White"
                    CornerRadius="10"
                    Padding="18"
                        Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Client info header -->
                            <Border Grid.Row="0"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Selected Client"
                                       FontSize="13"
                                       Foreground="#6B7280"/>
                                        <TextBlock Text="0001 • Hristijan Cupetreski"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#111827"
                                       Margin="0,4,0,0"/>
                                        <TextBlock Text="Client profile and related document actions."
                                       FontSize="13"
                                       Foreground="#6B7280"
                                       Margin="0,6,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                                        <Button Content="Edit Client"
                                    Width="100"
                                    Height="34"
                                    Margin="0,0,10,0"/>
                                        <Button Content="Save Changes"
                                    Width="110"
                                    Height="34"
                                    FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Client details form -->
                            <Border Grid.Row="2"
                                Background="#FFFFFF"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="Client Information"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Full Name:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Height="34" x:Name="FullNameBox"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Date of Birth:" VerticalAlignment="Center"/>
                                    <DatePicker Grid.Row="4" Grid.Column="1" Height="34" x:Name="DateBirthBox"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Phone:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="6" Grid.Column="1" Height="34" x:Name="PhoneBox"/>

                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Passport Number:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="8" Grid.Column="1" Height="34" x:Name="PassportBox"/>

                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Notes" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="10" Grid.Column="1" Height="34" x:Name="NotesBox"/>
                                </Grid>
                            </Border>

                            <!-- Document actions -->
                            <Border Grid.Row="4"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Document Actions"
                                   FontSize="18"
                                   FontWeight="Bold"/>

                                    <UniformGrid Grid.Row="2" Columns="4">
                                        <Button Content="Create Invoice" Height="42" Margin="0,0,10,0"/>
                                        <Button Content="Create Contract" Height="42" Margin="0,0,10,0"/>
                                        <Button Content="Create Offer" Height="42" Margin="0,0,10,0"/>
                                        <Button Content="Open Payments" Height="42"/>
                                    </UniformGrid>
                                </Grid>
                            </Border>

                            <!-- Document history -->
                            <Border Grid.Row="6"
                        Background="#FFFFFF"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Client Document History"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12"/>

                                    <Border Background="#F9FAFB"
                                CornerRadius="6"
                                Padding="12"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Margin="0,0,0,10">
                                        <TextBlock Text="Invoice #INV-2026-001"/>
                                    </Border>

                                    <Border Background="#F9FAFB"
                                CornerRadius="6"
                                Padding="12"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Margin="0,0,0,10">
                                        <TextBlock Text="Contract #CON-2026-004"/>
                                    </Border>

                                    <Border Background="#F9FAFB"
                                CornerRadius="6"
                                Padding="12"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1">
                                        <TextBlock Text="Offer #OFF-2026-002"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Border>

                <Border x:Name="AddNewClientView"
                    Background="White"
                    CornerRadius="10"
                    Padding="18"
                    Visibility="Collapsed"
                        >
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Border Background="White" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Add New Client"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="20"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Full Name:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Height="34"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Date of Birth:" VerticalAlignment="Center"/>
                                    <DatePicker Grid.Row="2" Grid.Column="1" Height="34"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Phone:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Height="34"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Passport Number:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="6" Grid.Column="1" Height="34"/>

                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Notes:" VerticalAlignment="Top"/>
                                    <TextBox Grid.Row="8"
                                         Grid.Column="1"
                                         Height="100"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>

                                    <StackPanel Grid.Row="10"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                        <Button Content="Cancel"
                                            Width="100"
                                            Height="36"
                                            Margin="0,0,10,0"
                                            Click="CancelAddNewClient_Click"/>
                                        <Button Content="Save Client"
                                            Width="120"
                                            Height="36"
                                            FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </ScrollViewer>
                </Border>

            </Grid>
            
        </Grid>
    </Grid>
</Window>
