<Window x:Class="MCS_MyTravel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Client Document Manager"
        WindowState="Maximized"
        MinHeight="650"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="10"
                Padding="18"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="My Travel Agency Manager"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>
                    <TextBlock Text=""
                               FontSize="13"
                               Foreground="#6B7280"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Booking"
                            Width="90"
                            Height="34"
                            Margin="0,0,10,0"/>
                    <Button Content="Refresh"
                            Width="90"
                            Height="34"
                            Margin="0,0,10,0"/>
                    <Button Content="Add New Client"
                            Width="130"
                            Height="34"
                            FontWeight="SemiBold"
                            Click="AddNewClient_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left sidebar -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Client Database"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>

                    <TextBox Grid.Row="1"
                             Height="34"
                             Margin="0,12,0,10"
                             VerticalContentAlignment="Center"
                             Text="Search by name, surname, or client ID"/>

                    <ComboBox Grid.Row="2"
                              Height="34"
                              Margin="0,0,0,12"
                              SelectedIndex="0">
                        <ComboBoxItem Content="All Clients"/>
                        <ComboBoxItem Content="Recently Added"/>
                        <ComboBoxItem Content="With Active Documents"/>
                        <ComboBoxItem Content="Archived"/>
                    </ComboBox>

                    <Border Grid.Row="3"
                            Background="#F9FAFB"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8">
                        <ListBox BorderThickness="0"
                                 Background="Transparent"
                                 SelectionChanged="ClientList_SelectionChanged"
                                 x:Name="ClientList"
                                 ItemsSource="{Binding Clients}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                            FontSize="14">
                                            <Run Text="{Binding FullName}" />
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>
                    </Border>

                </Grid>
            </Border>

            <!-- right side -->
            <Grid Grid.Column="2">

                <!-- DOCUMENT PANEL CHOICE STATEOR WHATEVETHEFUCK -->
                <Border x:Name="DocumentChoiceView"
        Background="White"
        CornerRadius="10"
        Padding="18"
        Visibility="Collapsed">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Create Document"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#1F2937"/>
                            <TextBlock Text="Select the type of document you want to create."
                       FontSize="13"
                       Foreground="#6B7280"
                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <!-- Document type picker -->
                        <Border Grid.Row="2"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Background="#F9FAFB">
                            <StackPanel>
                                <TextBlock Text="Document Type"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#374151"
                           Margin="0,0,0,12"/>

                                <UniformGrid Columns="3" Rows="1">

                                    <Border x:Name="AgreementCard"
                            Margin="0,0,10,0"
                            CornerRadius="8"
                            BorderBrush="#E5E7EB"
                            BorderThickness="2"
                            Background="White"
                            Padding="20"
                            Cursor="Hand"
                            MouseLeftButtonUp="AgreementCard_Click">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="📄"
                                       FontSize="32"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>
                                            <TextBlock Text="Agreement"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Foreground="#1F2937"/>
                                            <TextBlock Text="Client agreement document"
                                       FontSize="12"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"
                                       TextAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="VoucherCard"
                            Margin="0,0,10,0"
                            CornerRadius="8"
                            BorderBrush="#E5E7EB"
                            BorderThickness="2"
                            Background="White"
                            Padding="20"
                            Cursor="Hand"
                            MouseLeftButtonUp="VoucherCard_Click">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="🎫"
                                       FontSize="32"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>
                                            <TextBlock Text="Voucher"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Foreground="#1F2937"/>
                                            <TextBlock Text="Travel voucher document"
                                       FontSize="12"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"
                                       TextAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="InvoiceCard"
                            CornerRadius="8"
                            BorderBrush="#E5E7EB"
                            BorderThickness="2"
                            Background="White"
                            Padding="20"
                            Cursor="Hand"
                            MouseLeftButtonUp="InvoiceCard_Click">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="🧾"
                                       FontSize="32"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>
                                            <TextBlock Text="Invoice"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Foreground="#1F2937"/>
                                            <TextBlock Text="Payment invoice document"
                                       FontSize="12"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"
                                       TextAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                </UniformGrid>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>

                <!-- booking panel -->
                <Border x:Name="BookingPanel" 
                    Background="White"
                    CornerRadius="10"
                    Padding="18"
                    Visibility="Collapsed">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- HEADER -->
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Create Booking"
                   FontSize="24"
                   FontWeight="Bold"/>
                                <TextBlock Text="Enter the booking information for the selected client."
                   Margin="0,6,0,0"
                   FontSize="13"
                   Opacity="0.75"/>
                            </StackPanel>

                            <!-- SELECTED CLIENT INFO -->
                            <Border Grid.Row="2"
            Padding="16"
            CornerRadius="8"
            Background="#F5F5F5"
            BorderBrush="#DDDDDD"
            BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"
                       Text="Selected Client"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="Full Name:"
                       VerticalAlignment="Center"/>
                                    <TextBlock x:Name="BookingClientNameText"
                       Grid.Row="2"
                       Grid.Column="1"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Text="No client selected"/>

                                    <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Text="Passport Number:"
                       VerticalAlignment="Center"/>
                                    <TextBlock x:Name="BookingClientPassportText"
                       Grid.Row="4"
                       Grid.Column="1"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Text="-"/>
                                </Grid>
                            </Border>

                            <!-- BOOKING FORM -->
                            <Border Grid.Row="4"
                            Padding="16"
                            CornerRadius="8"
                            Background="White"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"
                       Text="Booking Information"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="Start Date:"
                       VerticalAlignment="Center"/>
                                    <DatePicker x:Name="BookingStartDatePicker"
                        Grid.Row="2"
                        Grid.Column="1"
                        Height="34"/>

                                    <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Text="End Date:"
                       VerticalAlignment="Center"/>
                                    <DatePicker x:Name="BookingEndDatePicker"
                        Grid.Row="4"
                        Grid.Column="1"
                        Height="34"/>

                                    <TextBlock Grid.Row="6"
                       Grid.Column="0"
                       Text="Place of Stay:"
                       VerticalAlignment="Center"/>
                                    <TextBox x:Name="BookingPlaceTextBox"
                     Grid.Row="6"
                     Grid.Column="1"
                     Height="34"/>
                                    <TextBlock Grid.Row="8"
                              Grid.Column="0"
                              Text="Type of Stay:"
                              VerticalAlignment="Center"/>
                                    <TextBox x:Name="BookingPlaceTypeTextBox"
                                Grid.Row="8"
                                Grid.Column="1"
                                Height="34"/>

                                    <TextBlock Grid.Row="10"
                       Grid.Column="0"
                       Text="Total Price:"
                       VerticalAlignment="Center"/>
                                    <TextBox x:Name="BookingTotalPriceTextBox"
                     Grid.Row="10"
                     Grid.Column="1"
                     Height="34"/>

                                    <TextBlock Grid.Row="12"
                       Grid.Column="0"
                       Text="Notes:"
                       VerticalAlignment="Top"
                       Margin="0,6,0,0"/>
                                    <TextBox x:Name="BookingNotesTextBox"
                     Grid.Row="12"
                     Grid.Column="1"
                     Height="90"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>

                            <!-- PASSENGERS -->
                            <!-- PASSENGERS -->
                            <Border Grid.Row="6"
                                Padding="16"
                                CornerRadius="8"
                                Background="White"
                                BorderBrush="#DDDDDD"
                                BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                   Text="Passengers"
                   FontSize="18"
                   FontWeight="Bold"/>

                                    <!-- Add passenger form -->
                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="6"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Full Name" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Passport ID" Margin="0,0,0,4"/>

                                        <TextBox x:Name="PassengerFullNameTextBox"
                                             Grid.Row="2"
                                             Grid.Column="0"
                                             Height="34"/>

                                        <TextBox x:Name="PassengerPassportTextBox"
                                             Grid.Row="2"
                                             Grid.Column="2"
                                             Height="34"/>

                                        <Button x:Name="AddPassengerButton"
                                            Grid.Row="2"
                                            Grid.Column="4"
                                            Height="34"
                                            Content="Add Passenger"
                                            Click="AddPassengerButton_Click"/>
                                    </Grid>

                                    <!-- Passenger list -->
                                    <Grid Grid.Row="4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                           Text="Added Passengers"
                                           FontWeight="SemiBold"/>

                                        <Border Grid.Row="2"
                                            BorderBrush="#DDDDDD"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8">
                                            <StackPanel>
                                                <!-- Column headers -->
                                                <Grid Margin="10,4,10,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="90"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Full Name" FontWeight="SemiBold" Foreground="#6B7280"/>
                                                    <TextBlock Grid.Column="2" Text="Passport ID" FontWeight="SemiBold" Foreground="#6B7280"/>
                                                </Grid>

                                                <ListBox x:Name="PassengerListBox"
                             BorderThickness="0"
                             Background="Transparent"
                             HorizontalContentAlignment="Stretch"
                             ItemsSource="{Binding CurrentBooking.Passengers}">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                            <Setter Property="Padding" Value="0"/>
                                                            <Setter Property="Margin" Value="0"/>
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ListBoxItem">
                                                                        <ContentPresenter/>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10"
                                        Margin="0,0,0,6"
                                        Background="#F9FAFB">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="16"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="16"/>
                                                                        <ColumnDefinition Width="90"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <TextBox Grid.Column="0"
                                                 Height="34"
                                                 VerticalContentAlignment="Center"
                                                 Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>

                                                                    <TextBox Grid.Column="2"
                                                 Height="34"
                                                 VerticalContentAlignment="Center"
                                                 Text="{Binding PassportId, UpdateSourceTrigger=PropertyChanged}"/>

                                                                    <Button Grid.Column="4"
                                                Height="34"
                                                Content="Remove"
                                                Click="RemovePassengerButton_Click"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- ACTION BUTTONS -->
                            <StackPanel Grid.Row="8"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                                <Button x:Name="CancelBookingButton"
                                Content="Cancel"
                                Width="120"
                                Height="36"
                                Margin="0,0,12,0"
                                Click="CancelBookingButton_Click"/>

                                <Button x:Name="SaveBookingButton"
                                Content="Save Booking"
                                Width="140"
                                Height="36"
                                Click="SaveBookingButton_Click"/>
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>
                </Border>

                <!-- PAYMENTS PANEL -->
                <Border x:Name="PaymentsPanel"
                    Background="White"
                    CornerRadius="10"
                    Padding="18"
                    Visibility="Collapsed">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- HEADER -->
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Payments &amp; Pricing"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#1F2937"/>
                                <TextBlock Text="Enter the price breakdown and track payments for this booking."
                           FontSize="13"
                           Foreground="#6B7280"
                           Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- SECTION 1: Price Components -->
                            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="16"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                               Text="Price Components"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#1F2937"
                               Margin="0,0,0,4"/>

                                    <!-- Hotel Price -->
                                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Hotel Price:"
                               VerticalAlignment="Center"/>
                                    <TextBox x:Name="HotelPriceBox"
                             Grid.Row="2" Grid.Column="1"
                             Height="34"
                             TextChanged="PriceField_Changed"/>

                                    <!-- Travel Price -->
                                    <CheckBox x:Name="IncludeTravelCheckBox"
                              Grid.Row="4" Grid.Column="0"
                              Content="Include Travel Price"
                              VerticalAlignment="Center"
                              Checked="PriceCheckBox_Changed"
                              Unchecked="PriceCheckBox_Changed"/>
                                    <TextBox x:Name="TravelPriceBox"
                             Grid.Row="4" Grid.Column="1"
                             Height="34"
                             IsEnabled="False"
                             TextChanged="PriceField_Changed"/>

                                    <!-- Insurance -->
                                    <CheckBox x:Name="IncludeInsuranceCheckBox"
                              Grid.Row="6" Grid.Column="0"
                              Content="Include Insurance"
                              VerticalAlignment="Center"
                              Checked="PriceCheckBox_Changed"
                              Unchecked="PriceCheckBox_Changed"/>
                                    <TextBox x:Name="InsurancePriceBox"
                             Grid.Row="6" Grid.Column="1"
                             Height="34"
                             IsEnabled="False"
                             TextChanged="PriceField_Changed"/>

                                    <!-- Taxes -->
                                    <CheckBox x:Name="IncludeTaxesCheckBox"
                              Grid.Row="8" Grid.Column="0"
                              Content="Include Taxes"
                              VerticalAlignment="Center"
                              Checked="PriceCheckBox_Changed"
                              Unchecked="PriceCheckBox_Changed"/>
                                    <TextBox x:Name="TaxesPriceBox"
                             Grid.Row="8" Grid.Column="1"
                             Height="34"
                             IsEnabled="False"
                             TextChanged="PriceField_Changed"/>

                                    <!-- Calculated Total -->
                                    <Border Grid.Row="10" Grid.ColumnSpan="2"
                            Background="#F0FDF4"
                            BorderBrush="#BBF7D0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Calculated Total Price"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#166534"
                                       VerticalAlignment="Center"/>
                                            <TextBlock x:Name="CalculatedTotalText"
                                       Grid.Column="1"
                                       Text="0.00"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#166534"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                            <!-- SECTION 2: Payment Entry -->
                            <Border Grid.Row="4"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="16"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                               Text="Add Payment"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#1F2937"
                               Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Payment Amount:"
                               VerticalAlignment="Center"/>
                                    <TextBox x:Name="PaymentAmountBox"
                             Grid.Row="2" Grid.Column="1"
                             Height="34"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Text="Payment Date:"
                               VerticalAlignment="Center"/>
                                    <DatePicker x:Name="PaymentDatePicker"
                                Grid.Row="4" Grid.Column="1"
                                Height="34"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0"
                               Text="Type / Notes:"
                               VerticalAlignment="Center"/>
                                    <TextBox x:Name="PaymentNotesBox"
                             Grid.Row="6" Grid.Column="1"
                             Height="34"/>

                                    <Button Grid.Row="8" Grid.Column="1"
                            x:Name="AddPaymentButton"
                            Content="Add Payment"
                            Height="36"
                            HorizontalAlignment="Right"
                            Width="140"
                            Click="AddPaymentButton_Click"/>
                                </Grid>
                            </Border>

                            <!-- SECTION 3: Payment Summary -->
                            <Border Grid.Row="6"
                    Background="#F9FAFB"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                               Text="Payment Summary"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Total Price -->
                                        <Border Grid.Column="0"
                                Background="White"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,0,10,0">
                                            <StackPanel>
                                                <TextBlock Text="Total Price"
                                           FontSize="12"
                                           Foreground="#6B7280"/>
                                                <TextBlock x:Name="SummaryTotalText"
                                           Text="0.00"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#1F2937"
                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Paid So Far -->
                                        <Border Grid.Column="1"
                                Background="White"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,0,10,0">
                                            <StackPanel>
                                                <TextBlock Text="Paid So Far"
                                           FontSize="12"
                                           Foreground="#6B7280"/>
                                                <TextBlock x:Name="SummaryPaidText"
                                           Text="0.00"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#16A34A"
                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Remaining -->
                                        <Border Grid.Column="2"
                                Background="White"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,0,10,0">
                                            <StackPanel>
                                                <TextBlock Text="Remaining"
                                           FontSize="12"
                                           Foreground="#6B7280"/>
                                                <TextBlock x:Name="SummaryRemainingText"
                                           Text="0.00"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#DC2626"
                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Paid % -->
                                        <Border Grid.Column="3"
                                Background="White"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Paid %"
                                           FontSize="12"
                                           Foreground="#6B7280"/>
                                                <TextBlock x:Name="SummaryPercentText"
                                           Text="0%"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#2563EB"
                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Border>

                <!-- no CLIENTS VIEW FROM HERE -->
                <Border x:Name="NoClientSelectedView"
                        Background="White"
                        CornerRadius="10"
                        Padding="18"
                        Visibility="Collapsed">
                    <Border Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="30"
                        Width="420"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="No client selected"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                            <TextBlock Text="Select a client from the left side or add a new client to begin."
                           FontSize="14"
                           Foreground="#6B7280"
                           TextAlignment="Center"
                           Margin="0,0,0,20"/>
                            <Button Content="Add New Client"
                        Width="150"
                        Height="36"
                        Click="AddNewClient_Click"/>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- SELECTED CLIENTS VIEW -->
                <Border x:Name="SelectedClientView"
                    Background="White"
                    CornerRadius="10"
                    Padding="18"
                        Visibility="Visible">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Client info header -->
                            <Border Grid.Row="0"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock x:Name="ClientNameHeader"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#111827"
                                       Margin="0,4,0,0"/>
                                        <TextBlock Text="Профил и Информации"
                                       FontSize="13"
                                       Foreground="#6B7280"
                                       Margin="0,6,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                                        <Button x:Name="EditButton"
                                                Content="Edit Client"
                                    Width="100"
                                    Height="34"
                                    Margin="0,0,10,0"
                                                Click="EditButton_Click"
                                                IsEnabled="True"/>
                                        <Button x:Name="SaveChangesButton"
                                            Content="Save Changes"
                                    Width="110"
                                    Height="34"
                                    FontWeight="SemiBold"
                                                Click="SaveNewClient_Click"
                                                IsEnabled="False"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Client details form -->
                            <Border Grid.Row="2"
                                Background="#FFFFFF"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       Text="Client Information"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Full Name:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Height="34" x:Name="FullNameBox" IsEnabled="False"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Date of Birth:" VerticalAlignment="Center"/>
                                    <DatePicker Grid.Row="4" Grid.Column="1" Height="34" x:Name="DateBirthBox" IsEnabled="False"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Phone:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="6" Grid.Column="1" Height="34" x:Name="PhoneBox" IsEnabled="False"/>

                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Passport Number:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="8" Grid.Column="1" Height="34" x:Name="PassportBox" IsEnabled="False"/>

                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Notes" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="10" Grid.Column="1" Height="34" x:Name="NotesBox" IsEnabled="False"/>
                                </Grid>
                            </Border>

                            <!-- Document history -->
                            <Border Grid.Row="6"
                                    Background="#FFFFFF"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Client Document History"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>

                                    <Border Background="#F9FAFB"
                                        CornerRadius="6"
                                        Padding="12"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        Margin="0,0,0,10">
                                        <TextBlock Text="Invoice #INV-2026-001"/>
                                    </Border>

                                    <Border Background="#F9FAFB"
                                        CornerRadius="6"
                                        Padding="12"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        Margin="0,0,0,10">
                                        <TextBlock Text="Contract #CON-2026-004"/>
                                    </Border>

                                    <Border Background="#F9FAFB"
                                        CornerRadius="6"
                                        Padding="12"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1">
                                        <TextBlock Text="Offer #OFF-2026-002"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Payment History -->
                            <Border Grid.Row="8"
                                Background="#FFFFFF"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                                <StackPanel>

                                    <!-- Header row -->
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Payment History"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>

                                        <Button Grid.Column="1"
                                            Content="+ Add Payment"
                                            Width="120"
                                            Height="32"
                                            Click="AddPaymentFromClientView_Click"/>
                                    </Grid>

                                    <!-- Column headers -->
                                    <Border Background="#F3F4F6"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="ID"
                           FontWeight="SemiBold"
                           Foreground="#6B7280"
                           FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="Date"
                           FontWeight="SemiBold"
                           Foreground="#6B7280"
                           FontSize="12"/>
                                            <TextBlock Grid.Column="2" Text="Amount"
                           FontWeight="SemiBold"
                           Foreground="#6B7280"
                           FontSize="12"/>
                                            <TextBlock Grid.Column="3" Text="Note"
                           FontWeight="SemiBold"
                           Foreground="#6B7280"
                           FontSize="12"/>
                                        </Grid>
                                    </Border>

                                    <!-- Payment list -->
                                    <ListBox x:Name="PaymentHistoryList"
                 BorderThickness="0"
                 Background="Transparent"
                 ItemsSource="{Binding CurrentBooking.Payments}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F9FAFB"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,10"
                            Margin="0,0,0,6"
                            Cursor="Hand">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="100"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                       Text="{Binding Id}"
                                       Foreground="#6B7280"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>

                                                        <TextBlock Grid.Column="1"
                                       Text="{Binding Date, StringFormat=dd/MM/yyyy}"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>

                                                        <TextBlock Grid.Column="2"
                                       Text="{Binding Amount, StringFormat={}{0:F2}}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#16A34A"
                                       VerticalAlignment="Center"/>

                                                        <TextBlock Grid.Column="3"
                                       Text="{Binding Note}"
                                       FontSize="13"
                                       Foreground="#6B7280"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Empty state -->
                                    <Border x:Name="NoPaymentsPlaceholder"
                Background="#F9FAFB"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="6"
                Padding="20">
                                        <TextBlock Text="No payments recorded yet."
                       Foreground="#9CA3AF"
                       HorizontalAlignment="Center"
                       FontSize="13"/>
                                    </Border>

                                </StackPanel>
                            </Border>

                        </Grid>
                    </ScrollViewer>
                </Border>

                <!-- ADDING NEW CLIENT VIEW -->
                <Border x:Name="AddNewClientView"
                    Background="White"
                    CornerRadius="10"
                    Padding="18"
                    Visibility="Collapsed"
                        >
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Border Background="White" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Add New Client"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="20"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Full Name:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Height="34" Text="{Binding CurrentClient.FullName, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Date of Birth:" VerticalAlignment="Center"/>
                                    <DatePicker Grid.Row="2" Grid.Column="1" Height="34" SelectedDate="{Binding CurrentClient.DateOfBirth, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Phone:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Height="34" Text="{Binding CurrentClient.Phone, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Passport Number:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="6" Grid.Column="1" Height="34" Text="{Binding CurrentClient.PassportId, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Notes:" VerticalAlignment="Top"/>
                                    <TextBox Grid.Row="8"
                                     Grid.Column="1"
                                     Height="100"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding CurrentClient.Notes, UpdateSourceTrigger=PropertyChanged}" />

                                    <StackPanel Grid.Row="10"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                        <Button Content="Cancel"
                                            Width="100"
                                            Height="36"
                                            Margin="0,0,10,0"
                                            Click="CancelAddNewClient_Click"/>
                                        <Button x:Name="SaveClientButton"
                                            Content="Save Client"
                                            Width="120"
                                            Height="36"
                                            FontWeight="SemiBold"
                                            Click="SaveNewClient_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
